<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".AdminDashboard">


<!-- Header Section -->

<View
    android:id="@+id/headerBackground"
    android:layout_width="412dp"
    android:layout_height="137dp"
    android:layout_marginBottom="15dp"
    android:background="@drawable/bgredg"
    app:layout_constraintBottom_toTopOf="@+id/searchContainer"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintTop_toTopOf="parent"
    tools:ignore="MissingConstraints" />

<ImageButton
    android:id="@+id/menuButton"
    android:layout_width="48dp"
    android:layout_height="48dp"
    android:layout_marginStart="16dp"
    android:layout_marginTop="16dp"
    android:background="?attr/selectableItemBackgroundBorderless"
    android:src="@android:drawable/ic_menu_sort_by_size"
    android:contentDescription="Menu"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintTop_toTopOf="parent"
    app:tint="@color/green"
    tools:ignore="HardcodedText" />

<TextView
    android:id="@+id/portalTitle"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginStart="12dp"
    android:text="@string/admin_title"
    android:textColor="@color/green"
    android:textSize="20sp"
    android:textStyle="bold"
    app:layout_constraintBottom_toBottomOf="@+id/menuButton"
    app:layout_constraintStart_toEndOf="@+id/menuButton"
    app:layout_constraintTop_toTopOf="@+id/menuButton" />


    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/profileImage"
        android:layout_width="72dp"
        android:layout_height="77dp"
        android:layout_marginEnd="16dp"
        android:scaleType="centerCrop"
        android:src="@drawable/hillsid"
        app:layout_constraintBottom_toBottomOf="@+id/portalTitle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/portalTitle"
        app:shapeAppearance="@style/CircleImage" />

<TextView
    android:id="@+id/welcomeText"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginTop="24dp"
    android:text="Hello, Admin"
    android:textColor="@color/red"
    android:textSize="18sp"
    android:textStyle="bold"
    app:layout_constraintStart_toStartOf="@+id/menuButton"
    app:layout_constraintTop_toBottomOf="@+id/menuButton" />

<TextView
    android:id="@+id/taglineText"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:text="Ready to manage!"
    android:textColor="#E0E0E0"
    android:textSize="14sp"
    app:layout_constraintStart_toStartOf="@+id/welcomeText"
    app:layout_constraintTop_toBottomOf="@+id/welcomeText" />

<!-- Search Bar -->
<LinearLayout
    android:id="@+id/searchContainer"
    android:layout_width="0dp"
    android:layout_height="50dp"
    android:layout_marginStart="20dp"
    android:layout_marginTop="20dp"
    android:layout_marginEnd="20dp"
    android:background="@drawable/search_bg"
    android:elevation="4dp"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintTop_toBottomOf="@+id/taglineText">

    <ImageView
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:src="@android:drawable/ic_menu_search"
        app:tint="@color/muted" />

    <EditText
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginStart="12dp"
        android:background="@android:color/transparent"
        android:hint="Search anything..."
        android:textSize="14sp" />
</LinearLayout>

<!-- Main Content -->
<androidx.core.widget.NestedScrollView
    android:layout_width="match_parent"
    android:layout_height="0dp"
    android:layout_marginTop="16dp"
    android:fillViewport="true"
    app:layout_constraintBottom_toTopOf="@+id/navCard"
    app:layout_constraintTop_toBottomOf="@+id/searchContainer">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Quick Roles"
                android:padding="4dp"
                android:textColor="@color/red"
                android:textSize="18sp"
                android:textStyle="bold" />

        </RelativeLayout>

        <!-- Quick Access Grid replaced with LinearLayouts for stability -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Row 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- Profile Card -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/addUserCard"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_margin="4dp"
                    app:cardBackgroundColor="#F0F7FF"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp"
                        android:clickable="false"
                        android:focusable="false">
                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/bgwhite"
                            android:padding="6dp"
                            android:src="@android:drawable/ic_menu_myplaces"
                            app:tint="#2196F3" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Add users"
                            android:textColor="@color/black"
                            android:textStyle="bold"
                            android:textSize="12sp" />

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Attendance Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_margin="4dp"
                    app:cardBackgroundColor="#F0FFF0"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp">
                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/bgwhite"
                            android:padding="6dp"
                            android:src="@android:drawable/ic_menu_today"
                            android:tint="@color/green" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Manage users"
                            android:textColor="@color/black"
                            android:textStyle="bold"
                            android:textSize="12sp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Disable or enable users"
                            android:textSize="10sp"
                            android:alpha="0.6" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- GradeSheet Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_margin="4dp"
                    app:cardBackgroundColor="#FFF9C4"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp">
                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/bgwhite"
                            android:padding="6dp"
                            android:src="@android:drawable/ic_menu_sort_alphabetically"
                            android:tint="#FBC02D"
                            tools:ignore="UseAppTint" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Update news &amp; announcements"
                            android:textColor="@color/black"
                            android:textStyle="bold"
                            android:textSize="12sp" />

                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- Row 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">

                <!-- Fees Details Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_margin="4dp"
                    app:cardBackgroundColor="#E0F2F1"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp">
                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/bgwhite"
                            android:padding="6dp"
                            android:src="@android:drawable/ic_menu_save"
                            android:tint="#00897B" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Fees Management"
                            android:textColor="@color/black"
                            android:textStyle="bold"
                            android:textSize="12sp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Payments &amp; history"
                            android:textSize="10sp"
                            android:alpha="0.6" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Exams Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_margin="4dp"
                    app:cardBackgroundColor="#F3E5F5"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp">
                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/bgwhite"
                            android:padding="6dp"
                            android:src="@android:drawable/ic_menu_agenda"
                            android:tint="#8E24AA"
                            tools:ignore="UseAppTint" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Exams"
                            android:textColor="@color/black"
                            android:textStyle="bold"
                            android:textSize="12sp"
                            tools:ignore="HardcodedTex" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Schedule &amp; results"
                            android:textSize="10sp"
                            android:alpha="0.6"
                            tools:ignore="HardcodedText,SmallSp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Library Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_margin="4dp"
                    app:cardBackgroundColor="#E3F2FD"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp">
                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/bgwhite"
                            android:padding="6dp"
                            android:src="@android:drawable/ic_menu_view"
                            android:tint="#1E88E5"
                            android:layout_gravity="left"
                            tools:ignore="UseAppTint" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Library"
                            android:textColor="@color/black"
                            android:textStyle="bold"
                            android:textSize="12sp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Books &amp; resources"
                            android:textSize="10sp"
                            android:alpha="0.6" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>
        </LinearLayout>



    </LinearLayout>
</androidx.core.widget.NestedScrollView>

<!-- Modern Bottom Navigation (Glassy) -->
<androidx.cardview.widget.CardView
    android:id="@+id/navCard"
    android:layout_width="match_parent"
    android:layout_height="80dp"
    android:layout_margin="16dp"
    app:cardBackgroundColor="@color/t1_white"
    app:cardCornerRadius="40dp"
    app:cardElevation="12dp"
    app:layout_constraintBottom_toBottomOf="parent"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintStart_toStartOf="parent">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Selection Pill Background -->
        <View
            android:id="@+id/navSelectionPill"
            android:layout_width="100dp"
            android:layout_height="match_parent"
            android:background="@drawable/nav_pill_bg"
            android:visibility="invisible" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="horizontal"
            android:weightSum="4">

            <!-- Home -->
            <LinearLayout
                android:id="@+id/navItemHome"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center">

                <LinearLayout
                    android:id="@+id/navContentHome"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="8dp">

                    <ImageView
                        android:id="@+id/navIconHome"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_menu_today"
                        app:tint="@color/green" />

                    <TextView
                        android:id="@+id/navTextHome"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="Home"
                        android:textColor="@color/white"
                        android:textStyle="bold"
                        android:visibility="gone" />
                </LinearLayout>
            </LinearLayout>

            <!-- Search -->
            <LinearLayout
                android:id="@+id/navItemSearch"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center">

                <LinearLayout
                    android:id="@+id/navContentSearch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="8dp">

                    <ImageView
                        android:id="@+id/navIconSearch"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/stat_notify_chat"
                        app:tint="@color/green" />

                    <TextView
                        android:id="@+id/navTextSearch"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="Search"
                        android:textColor="@color/white"
                        android:textStyle="bold"
                        android:visibility="gone" />
                </LinearLayout>
            </LinearLayout>

            <!-- Notification (Notify) -->
            <LinearLayout
                android:id="@+id/navItemNotify"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center">

                <LinearLayout
                    android:id="@+id/navContentNotify"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="8dp">

                    <ImageView
                        android:id="@+id/navIconNotify"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_menu_save"
                        app:tint="@color/green" />

                    <TextView
                        android:id="@+id/navTextNotify"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="Notify"
                        android:textColor="@color/white"
                        android:textStyle="bold"
                        android:visibility="gone" />
                </LinearLayout>
            </LinearLayout>

            <!-- Profile -->
            <LinearLayout
                android:id="@+id/navItemProfile"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center">

                <LinearLayout
                    android:id="@+id/navContentProfile"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="8dp">

                    <ImageView
                        android:id="@+id/navIconProfile"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_menu_myplaces"
                        app:tint="@color/green" />

                    <TextView
                        android:id="@+id/navTextProfile"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="Profile"
                        android:textColor="@color/white"
                        android:textStyle="bold"
                        android:visibility="gone" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>
</androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>
